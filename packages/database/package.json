        "cross-env": "^10.1.0",
        "rimraf": "^6.1.2",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "dotenv": "^17.2.4",
        "dotenv-safe": "^9.1.0",
        "pg": "^8.18.0",
        "reflect-metadata": "^0.2.2",
        "typeorm": "^0.3.28"
